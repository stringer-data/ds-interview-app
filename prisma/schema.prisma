generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Question system enums ---

enum DifficultyStep {
  STEP1_DEFINITION
  STEP2_INTUITION
  STEP3_APPLIED_PRODUCT
  STEP4_TECHNICAL_ASSUMPTIONS
  STEP5_HARD_CASE
}

enum Dimension {
  STRATEGY
  INTERPRETATION
  MATH
}

enum QuestionFlagReason {
  UNCLEAR
  WRONG
  TOO_EASY
  TOO_HARD
  OTHER
}

enum QuestionFlagStatus {
  OPEN
  RESOLVED
  IGNORED
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String?   @map("password_hash")
  firstName        String?   @map("first_name")
  lastName         String?   @map("last_name")
  tier             String    @default("free") // "free" | "paid"
  newsletterOptIn  Boolean   @default(false) @map("newsletter_opt_in")
  signupSource     String    @default("organic") @map("signup_source") // "organic" | "invite" | future: "referral", "campaign", etc.
  loginCount       Int       @default(0) @map("login_count")
  createdAt        DateTime  @default(now()) @map("created_at")
  firstLoginAt     DateTime? @map("first_login_at")
  lastLoginAt      DateTime? @map("last_login_at")

  attempts Attempt[]
  invites   Invite[]   @relation("CreatedInvites")
}

model Attempt {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  questionId  String   @map("question_id") // legacy: YAML id or slug; later can point at Question.slug
  followUpId   String?  @map("follow_up_id")
  topic       String
  theme       String
  difficulty  Int
  score       Int
  maxScore    Int      @default(4) @map("max_score")
  loggedAt    DateTime @default(now()) @map("logged_at")
  questionText String?  @map("question_text")  // question as shown to user
  answer       String?  // user's response

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([userId, loggedAt])
}

model Invite {
  id           String    @id @default(cuid())
  createdBy    String    @map("created_by")
  email        String?
  inviteeName  String?   @map("invitee_name") // optional name for who the invite is for
  inviteCode   String    @unique @map("invite_code")
  tierToGrant  String    @map("tier_to_grant") // "free" | "paid"
  createdAt    DateTime  @default(now()) @map("created_at")
  usedAt       DateTime? @map("used_at")

  creator User @relation("CreatedInvites", fields: [createdBy], references: [id], onDelete: Cascade)
  @@index([inviteCode])
}

// --- Question system core models ---

model Topic {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  slug      String     @unique
  questions Question[]
}

model Theme {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  slug      String     @unique
  questions Question[]
}

model Question {
  id              Int              @id @default(autoincrement())
  slug            String           @unique              // e.g. "design_itt_01"

  topicId         Int
  themeId         Int
  topic           Topic            @relation(fields: [topicId], references: [id])
  theme           Theme            @relation(fields: [themeId], references: [id])

  difficultyStep  DifficultyStep
  difficultyLevel Int                                  // 1–5

  dimension       Dimension?

  question        String
  referenceAnswer String?          @map("reference_answer")
  category        String?
  tags            String[]         @default([])         // Postgres text[]

  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  revisions       QuestionRevision[]
  ratings         QuestionRating[]
  flags           QuestionFlag[]
  comments        QuestionComment[]
}

model QuestionRevision {
  id         Int      @id @default(autoincrement())
  questionId Int
  question   Question @relation(fields: [questionId], references: [id])

  editorUserId String
  oldValue     Json
  newValue     Json
  createdAt    DateTime @default(now())
}

model QuestionRating {
  id         Int      @id @default(autoincrement())
  questionId Int
  question   Question @relation(fields: [questionId], references: [id])

  userId     String   // FK to User.id
  rating     Int      // 1–5, optional at UX level

  createdAt  DateTime @default(now())

  @@index([questionId])
  @@index([userId, questionId])
}

model QuestionFlag {
  id          Int                @id @default(autoincrement())
  questionId  Int
  question    Question           @relation(fields: [questionId], references: [id])

  userId      String
  reason      QuestionFlagReason
  notes       String?

  status      QuestionFlagStatus @default(OPEN)
  createdAt   DateTime           @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
}

model QuestionComment {
  id               Int               @id @default(autoincrement())
  questionId       Int
  question         Question          @relation(fields: [questionId], references: [id])

  userId           String
  body             String
  isOfficial       Boolean           @default(false)

  parentCommentId  Int?
  parentComment    QuestionComment?  @relation("QuestionCommentThread", fields: [parentCommentId], references: [id])
  replies          QuestionComment[] @relation("QuestionCommentThread")

  createdAt        DateTime          @default(now())
}
