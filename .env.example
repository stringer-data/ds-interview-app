# Question bank: path to ds-interview-trainer-v1/data/questions (absolute or relative to app root)
QUESTIONS_PATH=../ds-interview-trainer-v1/data/questions

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ds_trainer?schema=public"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-long-random-string

# Payments (Phase 1: set to false for testing with no paywall)
PAYMENTS_ENABLED=false
FREE_QUESTION_CAP=10
# When PAYMENTS_ENABLED=true:
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...

# LLM grading
OPENAI_API_KEY=sk-...

# Admin: comma-separated emails that can access /admin
ADMIN_EMAILS=you@example.com
